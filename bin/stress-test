#!/usr/bin/env node

const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const TESTS = [
  {
    name: 'Heavy JS (6-10s render)',
    url: 'https://authentic-travelers-434120.framer.app/',
    expectedTime: '< 15s',
  },
  {
    name: 'Medium JS (2-5s render)',
    url: 'https://daveos.fun/',
    expectedTime: '< 10s',
  },
  {
    name: 'Light JS (< 2s render)',
    url: 'https://ozon.studio/',
    expectedTime: '< 8s',
  },
  {
    name: 'Complex animations',
    url: 'https://humblefactory.ai/',
    expectedTime: '< 15s',
  },
];

console.log('🧪 STRESS TEST SUITE\n');
console.log('Testing exporter under different loads...\n');

const results = [];

for (const test of TESTS) {
  const testName = test.name;
  const testDir = `./stress-test-${testName.toLowerCase().replace(/\s+/g, '-')}`;

  console.log(`📊 Testing: ${testName}`);
  console.log(`   URL: ${test.url}`);
  console.log(`   Expected: ${test.expectedTime}`);

  try {
    const output = execSync(
      `node bin/framer-exporter export "${test.url}" "${testDir}"`,
      { encoding: 'utf8', stdio: 'pipe' }
    );

    // Extract timing from output
    const timeMatch = output.match(/⏱️  Total time: ([\d.]+)s/);
    const assetsMatch = output.match(/Found (\d+) assets/);
    const sizeMatch = output.match(/(\d+\.\d+) KB/);
    const brokenMatch = output.match(/(\d+) broken links/);

    const totalTime = timeMatch ? timeMatch[1] : 'unknown';
    const assets = assetsMatch ? assetsMatch[1] : 'unknown';
    const size = sizeMatch ? sizeMatch[1] : 'unknown';
    const broken = brokenMatch ? brokenMatch[1] : '0';

    console.log(`   ✅ Result: ${totalTime}s | ${assets} assets | ${size} KB | ${broken} broken\n`);

    results.push({
      test: testName,
      url: test.url,
      time: parseFloat(totalTime),
      assets: parseInt(assets),
      size: parseFloat(size),
      broken: parseInt(broken),
      status: 'PASS',
    });
  } catch (error) {
    console.log(`   ❌ FAILED: ${error.message}\n`);
    results.push({
      test: testName,
      url: test.url,
      status: 'FAIL',
      error: error.message,
    });
  }
}

// Summary
console.log('\n📈 STRESS TEST SUMMARY\n');
console.log('| Test | Time | Assets | Size | Broken | Status |');
console.log('|------|------|--------|------|--------|--------|');

for (const result of results) {
  if (result.status === 'PASS') {
    console.log(
      `| ${result.test} | ${result.time}s | ${result.assets} | ${result.size}KB | ${result.broken} | ✅ |`
    );
  } else {
    console.log(`| ${result.test} | - | - | - | - | ❌ |`);
  }
}

const passed = results.filter(r => r.status === 'PASS').length;
const total = results.length;
console.log(`\n${passed}/${total} tests passed\n`);

// Performance analysis
console.log('⚙️  PERFORMANCE ANALYSIS\n');

const times = results.filter(r => r.time).map(r => r.time);
const avgTime = (times.reduce((a, b) => a + b, 0) / times.length).toFixed(2);
const maxTime = Math.max(...times).toFixed(2);
const minTime = Math.min(...times).toFixed(2);

console.log(`Average crawl time: ${avgTime}s`);
console.log(`Fastest: ${minTime}s`);
console.log(`Slowest: ${maxTime}s`);
console.log(`Timeout buffer: ${(30 - maxTime).toFixed(2)}s remaining\n`);

// Warnings
console.log('⚠️  FINDINGS\n');

const highBroken = results.filter(r => r.broken && r.broken > 5);
if (highBroken.length > 0) {
  console.log('🔴 High broken link count:');
  for (const r of highBroken) {
    console.log(`   - ${r.test}: ${r.broken} broken links`);
  }
  console.log();
}

const slowSites = results.filter(r => r.time && r.time > 10);
if (slowSites.length > 0) {
  console.log('🟡 Slow sites (>10s):');
  for (const r of slowSites) {
    console.log(`   - ${r.test}: ${r.time}s`);
  }
  console.log();
}

const largeExports = results.filter(r => r.size && r.size > 500);
if (largeExports.length > 0) {
  console.log('🟠 Large exports (>500KB):');
  for (const r of largeExports) {
    console.log(`   - ${r.test}: ${r.size}KB`);
  }
  console.log();
}

console.log('✨ Stress test complete!\n');
